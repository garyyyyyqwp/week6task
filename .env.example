# --- LLM ---
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
OPENAI_MODEL=glm-4.6v

# --- Tavily Search ---
TAVILY_API_KEY=your_tavily_key_here

# --- Jina Reader (optional, zero-config) ---
# No API key needed — GET https://r.jina.ai/{url} for content extraction
# GET https://s.jina.ai/{query} for search

# --- Agent ---
AGENT_MAX_STEPS=10
